{
  "name": "wahubx-license-server",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "db:create": "wrangler d1 create wahubx-license-db",
    "db:init": "wrangler d1 execute wahubx-license-db --file=src/db/schema.sql",
    "db:init:remote": "wrangler d1 execute wahubx-license-db --file=src/db/schema.sql --remote"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20240405.0",
    "typescript": "^5.4.0",
    "wrangler": "^3.50.0"
  }
}
