# ───────── Node / pnpm ─────────
node_modules/
.pnpm-store/
pnpm-debug.log*
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ───────── Build output ─────────
dist/
build/
*.tsbuildinfo
.next/
.turbo/
.cache/

# ───────── Env & secrets ─────────
.env
.env.local
.env.*.local
*.pem
*.key
# M11 · dev/prod 密钥对存放处 · 永不入仓库
keys/
# dev snapshot backups · 防 smoke brick
dev-snapshots/
# M11 Day 5 · test .wupd + staging (root-level only · installer/staging 仍保)
/staging/

# ───────── Editor / OS ─────────
.vscode/
!.vscode/extensions.json
!.vscode/settings.template.json
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db
desktop.ini

# ───────── Claude Code workspace ─────────
.claude/
CLAUDE.md.local

# ───────── Logs ─────────
logs/
*.log

# ───────── Runtime data (local execution plane) ─────────
data/*
# 例外: §B.16 预置素材骨架随仓库走 (M7 填实物时再收尾)
!data/assets/
data/assets/*
!data/assets/_builtin/
backups/
tmp/
temp/

# ───────── Puppeteer / Chromium profiles ─────────
browser-profiles/
chrome-profile*/

# ───────── WA session / creds (never commit) ─────────
wa-session/
creds.json
*.wspack
*.wab
*.wupd

# ───────── Installer artifacts ─────────
installer/output/
installer/staging/app/
installer/staging/data/
installer/node_modules/
installer/deps/*/

# ───────── Test artifacts ─────────
coverage/
.nyc_output/
junit.xml

# ───────── Misc ─────────
*.pid
*.seed
*.tgz
.eslintcache

# 2026-04-24 · backend runtime data · 绝不提交
packages/backend/data/
packages/backend/logs/
