# ───────── Node / pnpm ─────────
node_modules/
.pnpm-store/
pnpm-debug.log*
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ───────── Build output ─────────
dist/
build/
*.tsbuildinfo
.next/
.turbo/
.cache/

# ───────── Env & secrets ─────────
.env
.env.local
.env.*.local
*.pem
*.key

# ───────── Editor / OS ─────────
.vscode/
!.vscode/extensions.json
!.vscode/settings.template.json
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db
desktop.ini

# ───────── Claude Code workspace ─────────
.claude/
CLAUDE.md.local

# ───────── Logs ─────────
logs/
*.log

# ───────── Runtime data (local execution plane) ─────────
data/
backups/
tmp/
temp/

