chrome-profile*/

# ───────── WA session / creds (never commit) ─────────
wa-session/
creds.json
*.wspack
*.wab
*.wupd

# ───────── Installer artifacts ─────────
installer/output/
installer/staging/app/
installer/staging/data/
installer/node_modules/
