# ───────── Server ─────────
NODE_ENV=development
PORT=3000
LOG_LEVEL=debug

# ───────── Database ─────────
DB_HOST=localhost
DB_PORT=5433
DB_USERNAME=wahubx
DB_PASSWORD=wahubx
DB_DATABASE=wahubx

# ───────── JWT (dev 随便填, 生产必须 32+ 字节随机) ─────────
JWT_ACCESS_SECRET=dev_access_secret_change_me_32_chars_min
JWT_REFRESH_SECRET=dev_refresh_secret_change_me_32_chars_min
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# ───────── Auth lockout ─────────
LOGIN_MAX_ATTEMPTS=5
LOGIN_LOCKOUT_SECONDS=900
BCRYPT_ROUNDS=12

# ───────── Redis / BullMQ (M3) ─────────
REDIS_HOST=localhost
REDIS_PORT=6380
# 可选
REDIS_PASSWORD=
REDIS_DB=0

# ───────── 调度器 (M3) ─────────
SCHEDULER_MAX_CONCURRENCY=6
SCHEDULER_POLL_INTERVAL_MS=3000
# 夜间窗口只放 warmup/maintenance 任务 (技术交接文档 § 5.2)
SCHEDULER_NIGHT_WINDOW_START=02:00
SCHEDULER_NIGHT_WINDOW_END=06:00

# M6 · AI 层
# 主密钥: openssl rand -hex 32 (32 字节 hex 串). 切勿提交真值.
APP_ENCRYPTION_KEY=__GENERATE_WITH_openssl_rand_hex_32__
# 全局 AI 文本改写冷启动开关 (运行时走 /ai-settings API 动态切换)
AI_TEXT_ENABLED=false
