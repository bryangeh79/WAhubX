# ───────── Server ─────────
NODE_ENV=development
PORT=3000
LOG_LEVEL=debug

# ───────── Database ─────────
DB_HOST=localhost
DB_PORT=5433
DB_USERNAME=wahubx
DB_PASSWORD=wahubx
DB_DATABASE=wahubx

# ───────── JWT (dev 随便填, 生产必须 32+ 字节随机) ─────────
JWT_ACCESS_SECRET=dev_access_secret_change_me_32_chars_min
JWT_REFRESH_SECRET=dev_refresh_secret_change_me_32_chars_min
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# ───────── Auth lockout ─────────
LOGIN_MAX_ATTEMPTS=5
LOGIN_LOCKOUT_SECONDS=900
BCRYPT_ROUNDS=12
