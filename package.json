{
  "name": "wahubx",
  "version": "0.1.0",
  "private": true,
  "description": "WhatsApp Multi-Account Automation Platform",
  "author": "Bryan Geh <bryangeh79@gmail.com>",
  "license": "UNLICENSED",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "db:up": "docker compose -f docker-compose.dev.yml up -d",
    "db:down": "docker compose -f docker-compose.dev.yml down",
    "db:logs": "docker compose -f docker-compose.dev.yml logs -f",
    "dev:backend": "pnpm --filter @wahubx/backend dev",
    "dev:frontend": "pnpm --filter @wahubx/frontend dev",
    "dev:all": "concurrently --kill-others-on-fail --names BE,FE --prefix-colors green,yellow \"pnpm dev:backend\" \"pnpm dev:frontend\"",
    "build:backend": "pnpm --filter @wahubx/backend build",
    "build:frontend": "pnpm --filter @wahubx/frontend build",
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "test": "pnpm -r test",
    "typecheck": "pnpm -r typecheck"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
